flowchart TB
  subgraph environmentBoundary["Environment authority boundary"]
    postgres[("PostgreSQL<br/>relational durable authority")]
    stem["Contained reconciliation stem"]
    supply["Pre-enrolled Cell supply supervisor"]
    postgres <==>|literal authority operations| stem
    postgres <==>|signed directives and observations| supply
  end

  subgraph hostA["Trusted host A"]
    cellA["Cell A<br/>generation 7"]
    chamberA["Chamber A"]
    adapterA["TypeScript adapter"]
    logicA["Authored graph"]
    cellA -->|contain and supervise| chamberA
    chamberA -->|host| adapterA
    adapterA -->|materialize and execute| logicA
  end

  subgraph hostB["Trusted host B"]
    cellB["Cell B<br/>generation 3"]
    chamberB["Chamber B"]
    adapterB["TypeScript adapter"]
    logicB["Authored task and actor owner"]
    cellB -->|contain and supervise| chamberB
    chamberB -->|host| adapterB
    adapterB -->|materialize and execute| logicB
  end

  stem ==> |exact reconciliation actions| cellA
  stem ==> |exact reconciliation actions| cellB
  supply -->|fresh pre-authorized generation| cellB
  cellA <-->|TLS 1.3, enrolled peer identity and generation-scoped messages| cellB
  cellA -.->|observations and evidence custody| postgres
  cellB -.->|observations and evidence custody| postgres

  classDef authority fill:#fff2cc,stroke:#8a6d1d,color:#172026;
  classDef trusted fill:#dcecff,stroke:#285f8f,color:#172026;
  classDef isolated fill:#eee5f7,stroke:#6c4c8f,color:#172026;
  classDef business fill:#ffe4dc,stroke:#9a4d38,color:#172026;
  class postgres authority;
  class stem,chamberA,chamberB,adapterA,adapterB isolated;
  class supply,cellA,cellB trusted;
  class logicA,logicB business;
