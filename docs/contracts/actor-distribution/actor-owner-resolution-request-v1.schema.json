{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cadenza.dev/contracts/actor-owner-resolution-request-v1.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract",
    "version",
    "environment_key",
    "actor_object_key",
    "actor_state_key_digest",
    "requesting_cell_key",
    "requesting_cell_generation_key",
    "resolved_at_unix_ms"
  ],
  "properties": {
    "contract": { "const": "cadenza.actor-owner-resolution-request" },
    "version": { "const": "1.0.0" },
    "environment_key": { "$ref": "#/$defs/key" },
    "actor_object_key": { "$ref": "#/$defs/key" },
    "actor_state_key_digest": { "$ref": "#/$defs/digest" },
    "requesting_cell_key": { "$ref": "#/$defs/key" },
    "requesting_cell_generation_key": { "$ref": "#/$defs/key" },
    "resolved_at_unix_ms": { "$ref": "#/$defs/positive" }
  },
  "$defs": {
    "key": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)*$"
    },
    "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "positive": { "type": "integer", "minimum": 1, "maximum": 9007199254740991 }
  }
}
