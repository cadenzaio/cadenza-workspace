{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cadenza.dev/contracts/actor-mutation-outcome-result-v1.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract",
    "version",
    "actor_mutation_key",
    "environment_key",
    "actor_object_key",
    "actor_state_key_digest",
    "actor_assignment_epoch",
    "status",
    "expected_state_version",
    "committed_state_version",
    "state_digest",
    "result",
    "result_digest",
    "committed_at_unix_ms",
    "resolved_at_unix_ms"
  ],
  "properties": {
    "contract": { "const": "cadenza.actor-mutation-outcome-result" },
    "version": { "const": "1.0.0" },
    "actor_mutation_key": { "$ref": "#/$defs/key" },
    "environment_key": { "$ref": "#/$defs/key" },
    "actor_object_key": { "$ref": "#/$defs/key" },
    "actor_state_key_digest": { "$ref": "#/$defs/digest" },
    "actor_assignment_epoch": { "$ref": "#/$defs/positive" },
    "status": { "enum": ["not_found", "committed"] },
    "expected_state_version": {
      "oneOf": [{ "$ref": "#/$defs/nonnegative" }, { "type": "null" }]
    },
    "committed_state_version": {
      "oneOf": [{ "$ref": "#/$defs/positive" }, { "type": "null" }]
    },
    "state_digest": {
      "oneOf": [{ "$ref": "#/$defs/digest" }, { "type": "null" }]
    },
    "result": {},
    "result_digest": {
      "oneOf": [{ "$ref": "#/$defs/digest" }, { "type": "null" }]
    },
    "committed_at_unix_ms": {
      "oneOf": [{ "$ref": "#/$defs/positive" }, { "type": "null" }]
    },
    "resolved_at_unix_ms": { "$ref": "#/$defs/positive" }
  },
  "$defs": {
    "key": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)*$"
    },
    "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "positive": {
      "type": "integer",
      "minimum": 1,
      "maximum": 9007199254740991
    },
    "nonnegative": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    }
  }
}
