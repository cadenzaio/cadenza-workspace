{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cadenza.dev/contracts/actor-lifecycle-evidence-v1.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract",
    "version",
    "observed_at_unix_ms",
    "event_type",
    "environment_key",
    "cell_key",
    "cell_generation_key",
    "actor_object_key",
    "actor_state_key_digest",
    "actor_assignment_epoch",
    "trace_key",
    "graph_execution_key",
    "task_execution_key",
    "actor_mutation_key",
    "expected_state_version",
    "committed_state_version",
    "state_digest",
    "result_digest",
    "owner_chamber_key",
    "owner_image_digest",
    "owner_image_epoch",
    "endpoint_provenance_digest",
    "execution_path",
    "affected_assignment_count",
    "outcome",
    "failure_class",
    "evidence_digest"
  ],
  "properties": {
    "contract": { "const": "cadenza.actor-lifecycle-evidence" },
    "version": { "const": "1.0.0" },
    "observed_at_unix_ms": { "$ref": "#/$defs/positive" },
    "event_type": {
      "enum": [
        "assignment_created",
        "assignment_continued",
        "assignment_failed",
        "assignment_relinquished",
        "invocation_routed",
        "hydration_succeeded",
        "hydration_failed",
        "commit_accepted",
        "commit_replayed",
        "commit_failed",
        "commit_outcome_committed",
        "commit_outcome_not_found",
        "commit_outcome_failed"
      ]
    },
    "environment_key": { "$ref": "#/$defs/key" },
    "cell_key": { "$ref": "#/$defs/key" },
    "cell_generation_key": { "$ref": "#/$defs/key" },
    "actor_object_key": { "oneOf": [{ "$ref": "#/$defs/key" }, { "type": "null" }] },
    "actor_state_key_digest": { "oneOf": [{ "$ref": "#/$defs/digest" }, { "type": "null" }] },
    "actor_assignment_epoch": { "oneOf": [{ "$ref": "#/$defs/positive" }, { "type": "null" }] },
    "trace_key": { "oneOf": [{ "type": "string", "pattern": "^trace\\.[a-f0-9-]{36}$" }, { "type": "null" }] },
    "graph_execution_key": { "oneOf": [{ "type": "string", "pattern": "^graph-execution\\.[a-f0-9-]{36}$" }, { "type": "null" }] },
    "task_execution_key": { "oneOf": [{ "type": "string", "pattern": "^task-execution\\.[a-f0-9-]{36}$" }, { "type": "null" }] },
    "actor_mutation_key": { "oneOf": [{ "$ref": "#/$defs/key" }, { "type": "null" }] },
    "expected_state_version": { "oneOf": [{ "$ref": "#/$defs/nonnegative" }, { "type": "null" }] },
    "committed_state_version": { "oneOf": [{ "$ref": "#/$defs/positive" }, { "type": "null" }] },
    "state_digest": { "oneOf": [{ "$ref": "#/$defs/digest" }, { "type": "null" }] },
    "result_digest": { "oneOf": [{ "$ref": "#/$defs/digest" }, { "type": "null" }] },
    "owner_chamber_key": { "oneOf": [{ "$ref": "#/$defs/key" }, { "type": "null" }] },
    "owner_image_digest": { "oneOf": [{ "$ref": "#/$defs/digest" }, { "type": "null" }] },
    "owner_image_epoch": { "oneOf": [{ "$ref": "#/$defs/positive" }, { "type": "null" }] },
    "endpoint_provenance_digest": { "oneOf": [{ "$ref": "#/$defs/digest" }, { "type": "null" }] },
    "execution_path": { "enum": ["local", "remote", "persistence", "drain"] },
    "affected_assignment_count": { "oneOf": [{ "$ref": "#/$defs/nonnegative" }, { "type": "null" }] },
    "outcome": { "enum": ["accepted", "continued", "created", "relinquished", "committed", "replayed", "not_found", "failed"] },
    "failure_class": { "oneOf": [{ "enum": ["unavailable", "stale", "conflict", "invalid_state", "pressure", "uncertain_commit", "evidence_custody"] }, { "type": "null" }] },
    "evidence_digest": { "$ref": "#/$defs/digest" }
  },
  "$defs": {
    "key": { "type": "string", "minLength": 1, "maxLength": 512, "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)*$" },
    "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "positive": { "type": "integer", "minimum": 1, "maximum": 9007199254740991 },
    "nonnegative": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 }
  }
}
