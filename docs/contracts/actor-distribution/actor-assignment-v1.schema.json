{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cadenza.dev/contracts/actor-assignment-v1.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract",
    "version",
    "assignment_key",
    "environment_key",
    "actor_object_key",
    "actor_state_key_digest",
    "actor_assignment_epoch",
    "placement_unit_key",
    "unit_definition_revision",
    "owner_replica_key",
    "owner_replica_assignment_epoch",
    "owner_cell_key",
    "owner_cell_generation_key",
    "owner_slice_key",
    "owner_chamber_key",
    "owner_image_digest",
    "owner_image_epoch",
    "owner_route_member_key",
    "outcome",
    "assigned_at_unix_ms",
    "valid_until_unix_ms"
  ],
  "properties": {
    "contract": { "const": "cadenza.actor-assignment" },
    "version": { "const": "1.0.0" },
    "assignment_key": { "$ref": "#/$defs/key" },
    "environment_key": { "$ref": "#/$defs/key" },
    "actor_object_key": { "$ref": "#/$defs/key" },
    "actor_state_key_digest": { "$ref": "#/$defs/digest" },
    "actor_assignment_epoch": { "$ref": "#/$defs/positive" },
    "placement_unit_key": { "$ref": "#/$defs/key" },
    "unit_definition_revision": { "$ref": "#/$defs/positive" },
    "owner_replica_key": { "$ref": "#/$defs/key" },
    "owner_replica_assignment_epoch": { "$ref": "#/$defs/positive" },
    "owner_cell_key": { "$ref": "#/$defs/key" },
    "owner_cell_generation_key": { "$ref": "#/$defs/key" },
    "owner_slice_key": { "$ref": "#/$defs/key" },
    "owner_chamber_key": { "$ref": "#/$defs/key" },
    "owner_image_digest": { "$ref": "#/$defs/digest" },
    "owner_image_epoch": { "$ref": "#/$defs/positive" },
    "owner_route_member_key": { "$ref": "#/$defs/key" },
    "outcome": { "enum": ["created", "continued"] },
    "assigned_at_unix_ms": { "$ref": "#/$defs/positive" },
    "valid_until_unix_ms": { "$ref": "#/$defs/positive" }
  },
  "$defs": {
    "key": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)*$"
    },
    "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "positive": { "type": "integer", "minimum": 1, "maximum": 9007199254740991 }
  }
}
