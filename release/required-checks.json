{
  "schema_version": 2,
  "repositories": [
    {
      "name": "cadenza-workspace",
      "checks": ["governance", "release-metadata", "DCO"]
    },
    { "name": "cadenza", "checks": ["core", "lint", "DCO"] },
    {
      "name": "cadenza-python",
      "checks": ["core (3.13.14)", "core (3.14.6)", "DCO"]
    },
    { "name": "cadenza-elixir", "checks": ["core", "DCO"] },
    { "name": "cadenza-csharp", "checks": ["core", "DCO"] },
    { "name": "cadenza-environment", "checks": ["environment", "DCO"] },
    { "name": "cadenza-chamber", "checks": ["chamber", "DCO"] },
    { "name": "cadenza-cell", "checks": ["cell", "DCO"] },
    {
      "name": "cadenza-reference-system",
      "checks": ["reference-system", "DCO"]
    }
  ],
  "post_tag_governance_checks": [
    {
      "repository": "cadenza",
      "context": "lint",
      "workflow": ".github/workflows/commitlint.yml",
      "decision": "docs/decisions/2026-07-23-core-commit-lint-post-tag-governance-repair.md"
    }
  ],
  "protected_branch": {
    "name": "main",
    "pull_request_required": true,
    "approving_reviews": 0,
    "dismiss_stale_reviews": true,
    "conversation_resolution_required": true,
    "linear_history_required": true,
    "force_push_allowed": false,
    "deletion_allowed": false,
    "administrator_bypass_allowed": false
  },
  "governance_ratchet": {
    "trigger": "before_second_write_authority_or_multi_maintainer_claim",
    "approving_reviews": 1
  }
}
